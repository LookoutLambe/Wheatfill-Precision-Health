generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Role {
  patient
  provider
  admin
}

enum AppointmentType {
  new_patient
  follow_up
}

enum AppointmentStatus {
  requested
  scheduled
  completed
  cancelled
}

enum OrderCategory {
  glp1
  labs
  supplements
  other
}

enum OrderStatus {
  new
  in_review
  ordered
  closed
}

enum BillingItemType {
  appointment
  order
  other
}

enum PaymentMethod {
  stripe
  clover
  manual_venmo
  /** Staff-recorded PayPal (e.g. link checkout); not from PayPal webhooks. */
  manual_paypal
}

enum ProviderPaymentProvider {
  stripe
  clover
}

enum PaymentStatus {
  pending
  requires_action
  succeeded
  failed
  refunded
  cancelled
}

enum SubscriptionStatus {
  active
  trialing
  past_due
  canceled
  unpaid
  incomplete
}

model PharmacyPartner {
  id        String @id @default(cuid())
  slug      String @unique
  name      String
  isActive  Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products  PharmacyProduct[]
}

model PharmacyProduct {
  id        String @id @default(cuid())
  partnerId String
  partner   PharmacyPartner @relation(fields: [partnerId], references: [id])

  sku       String
  name      String
  subtitle  String @default("")
  strength  String @default("")
  size      String @default("")
  priceCents Int
  currency  String @default("usd")
  isActive  Boolean @default(true)
  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([partnerId, sku])
  @@index([partnerId, isActive, sortOrder])
}

model User {
  id           String   @id @default(cuid())
  role         Role
  username     String   @unique
  passwordHash String
  displayName  String
  firstName    String?
  lastName     String?
  birthdate    DateTime?
  email        String?
  phone        String?

  address1     String?
  address2     String?
  city         String?
  state        String?
  postalCode   String?
  country      String? @default("US")
  deletedAt    DateTime?
  stripeCustomerId String?

  // Stripe Connect (provider payouts)
  stripeConnectedAccountId String?
  stripeOnboardingStatus   String? // e.g. 'pending','complete'
  stripeChargesEnabled     Boolean @default(false)
  stripePayoutsEnabled     Boolean @default(false)

  // Provider payment processor selection (which provider to use for new payments)
  activePaymentProvider ProviderPaymentProvider?

  // Clover connection details (encrypted at rest in DB)
  cloverEnv        String?
  cloverMerchantId String?
  cloverPrivateKeyEnc String?
  cloverPrivateKeyIv  String?
  cloverPrivateKeyTag String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  patientAppointments Appointment[] @relation("PatientAppointments")
  providerAppointments Appointment[] @relation("ProviderAppointments")
  ordersAsPatient Order[] @relation("OrdersAsPatient")
  ordersAsProvider Order[] @relation("OrdersAsProvider")
  blackoutDates BlackoutDate[]
  threadsAsPatient MessageThread[] @relation("ThreadAsPatient")
  threadsAsProvider MessageThread[] @relation("ThreadAsProvider")
  sentMessages MessageEvent[] @relation("SentMessages")
  auditEvents AuditLog[]

  paymentsAsPatient Payment[] @relation("PaymentsAsPatient")
  paymentsAsProvider Payment[] @relation("PaymentsAsProvider")
  subscriptions Subscription[]

  @@index([role])
  @@index([email])
}

model Appointment {
  id         String            @id @default(cuid())
  type       AppointmentType
  status     AppointmentStatus @default(requested)
  startTs    DateTime?
  endTs      DateTime?
  preferredDate String @default("")
  preferredTime String @default("")
  notes      String            @default("")
  source     String            @default("patient_request") // 'patient_request' | 'provider_scheduled'
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  deletedAt  DateTime?

  patientId  String
  providerId String
  patient    User @relation("PatientAppointments", fields: [patientId], references: [id])
  provider   User @relation("ProviderAppointments", fields: [providerId], references: [id])

  payments   Payment[] @relation("PaymentAppointment")

  @@index([providerId, startTs])
  @@index([patientId, startTs])
}

model BlackoutDate {
  id         String   @id @default(cuid())
  providerId String
  date       DateTime
  reason     String   @default("")
  createdAt  DateTime @default(now())

  provider   User @relation(fields: [providerId], references: [id])

  @@unique([providerId, date])
}

// Public site → team workspace (no Medplum). Read with TEAM_INBOX_KEY in Authorization.
model TeamInboxItem {
  id        String   @id @default(cuid())
  kind      String   // contact | online_booking
  status    String   @default("new") // new | handled
  fromName  String
  fromEmail String   @default("")
  body      String
  meta      String   @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

model Order {
  id         String       @id @default(cuid())
  category   OrderCategory
  item       String?
  request    String
  status     OrderStatus  @default(new)
  dosageNote String       @default("")
  providerNote String     @default("")
  pharmacyPartnerId String?

  // Shipping / consent (Warnock-style)
  shippingAddress1 String @default("")
  shippingAddress2 String @default("")
  shippingCity     String @default("")
  shippingState    String @default("")
  shippingPostalCode String @default("")
  shippingCountry  String @default("US")
  shippingCents    Int    @default(0)
  shippingInsuranceCents Int @default(0)
  agreedToShippingTerms Boolean @default(false)
  contactPermission Boolean @default(false)
  signatureName String @default("")
  signatureDate DateTime?
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  deletedAt  DateTime?

  patientId  String
  providerId String
  patient    User @relation("OrdersAsPatient", fields: [patientId], references: [id])
  provider   User @relation("OrdersAsProvider", fields: [providerId], references: [id])

  payments   Payment[] @relation("PaymentOrder")

  items      OrderItem[]
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  order     Order @relation(fields: [orderId], references: [id])

  partnerSlug String
  productSku  String
  name        String
  unitPriceCents Int
  quantity   Int

  createdAt DateTime @default(now())

  @@index([orderId])
}

model Payment {
  id        String        @id @default(cuid())
  method    PaymentMethod
  status    PaymentStatus @default(pending)
  amountCents Int
  currency  String        @default("usd")
  itemType  BillingItemType
  itemId    String?

  // Stripe identifiers
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  stripeSubscriptionId    String?

  // Clover Hosted Checkout identifiers
  cloverCheckoutSessionId String?
  cloverCheckoutHref      String?

  /** P2P / off-system payments: optional when the payer is not a named portal patient. */
  patientId  String?
  providerId String
  patient    User? @relation("PaymentsAsPatient", fields: [patientId], references: [id])
  /** Optional note: payer name, order ref, or how you matched the pay app. */
  p2pMemo    String? @map("p2p_memo")

  provider   User   @relation("PaymentsAsProvider", fields: [providerId], references: [id])

  appointmentId String?
  appointment   Appointment? @relation("PaymentAppointment", fields: [appointmentId], references: [id])

  orderId String?
  order   Order? @relation("PaymentOrder", fields: [orderId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([patientId, createdAt])
  @@index([providerId, createdAt])
  @@index([status])
}

model Subscription {
  id        String             @id @default(cuid())
  status    SubscriptionStatus
  planKey   String
  stripeSubscriptionId String  @unique
  currentPeriodEnd DateTime?
  cancelAtPeriodEnd Boolean @default(false)

  patientId String
  patient   User @relation(fields: [patientId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  @@index([patientId, status])
}

model MessageThread {
  id         String   @id @default(cuid())
  patientId  String
  providerId String
  createdAt  DateTime @default(now())

  patient    User @relation("ThreadAsPatient", fields: [patientId], references: [id])
  provider   User @relation("ThreadAsProvider", fields: [providerId], references: [id])
  events     MessageEvent[]

  @@unique([patientId, providerId])
}

model MessageEvent {
  id         String   @id @default(cuid())
  threadId   String
  senderId   String
  body       String
  createdAt  DateTime @default(now())

  thread     MessageThread @relation(fields: [threadId], references: [id])
  sender     User @relation("SentMessages", fields: [senderId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  entityType String
  entityId   String
  action     String
  beforeJson Json?
  afterJson  Json?
  ip         String?
  createdAt  DateTime @default(now())

  actor      User @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}

