PORT=8080
#
# Database (required): Prisma uses PostgreSQL only (`backend/prisma/schema.prisma`).
# - DATABASE_URL — runtime queries (use Supabase *pooler* in production if you use it)
# - DIRECT_URL — direct Postgres for migrations / `prisma db push` (non-pooled; port 5432 on Supabase)
#
# Local (Docker or native Postgres; create DB `wheatfill` or change the path):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wheatfill?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/wheatfill?schema=public
#
# Supabase (copy from Project Settings → Database; replace placeholders):
# Pooled (Session mode is easiest with Prisma; Transaction pooler needs ?pgbouncer=true on DATABASE_URL):
# DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<PASSWORD>@aws-0-<REGION>.pooler.supabase.com:5432/postgres
# Direct (always use for DIRECT_URL):
# DIRECT_URL=postgresql://postgres:<PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres?sslmode=require
#
# Behind Render / Fly / nginx: trust X-Forwarded-* for correct client IP (rate limits, audit logs).
# Auto-on in production when RENDER=true or FLY_APP_NAME is set; override with TRUST_PROXY=0 or TRUST_PROXY=1.
# TRUST_PROXY=1
JWT_SECRET=change_me_dev_only
# Required when NODE_ENV=production (comma-separated origins for credentialed browser API calls).
FRONTEND_ORIGIN=http://localhost:5176,https://wheatfillprecisionhealth.com,https://lookoutlambe.github.io

# Public POST abuse mitigation (in-memory per API process). Staff login is not rate-limited.
# PUBLIC_POST_RATE_MAX=40
# PUBLIC_POST_RATE_WINDOW_MS=3600000
JWT_ISSUER=wph-backend
JWT_AUDIENCE=wph-web

# Optional: read team inbox for scripts/integrations (GET /v1/team/inbox). Team on the site uses /auth/login + JWT instead.
TEAM_INBOX_KEY=

# Marketing / team sign-in (usernames: brett, bridgette, admin). Seeded on first run if users do not exist.
# TEAM_BRETT_PASSWORD=       # defaults to DEFAULT_PROVIDER_PASSWORD
# TEAM_BRIDGETTE_PASSWORD=wheatfill
# TEAM_ADMIN_PASSWORD=demonstration

# Session length for provider/patient sign-in (httpOnly cookie max-age matches JWT). Use shorter values for stricter security.
JWT_EXPIRES_IN=30d

# Default provider bootstrap (local/dev)
DEFAULT_PROVIDER_USERNAME=brett
DEFAULT_PROVIDER_PASSWORD=wheatfill

# Optional demo patient for pharmacy checkout (backend JWT / Stripe redirect)
DEFAULT_PATIENT_USERNAME=demo
DEFAULT_PATIENT_PASSWORD=wheatfill

# Clover Hosted Checkout (optional; no Clover webhook route in this API—use Stripe webhooks for card payments)
CLOVER_ENV=sandbox
CLOVER_MERCHANT_ID=
CLOVER_PRIVATE_KEY=

# Encryption key for storing provider secrets (32 bytes, base64 recommended)
APP_ENCRYPTION_KEY=

# Stripe (optional; for Stripe Connect + webhooks)
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=

PROVIDER_PRACTITIONER_ID=

# Optional: public video visit room URL (used by frontend patient portal)
# VITE_VIDEO_VISIT_URL=

