PORT=8080
DATABASE_URL=file:./dev.db
JWT_SECRET=change_me_dev_only
FRONTEND_ORIGIN=http://localhost:5176,https://wheatfillprecisionhealth.com,https://lookoutlambe.github.io
JWT_ISSUER=wph-backend
JWT_AUDIENCE=wph-web

# Default provider bootstrap (local/dev)
DEFAULT_PROVIDER_USERNAME=brett
DEFAULT_PROVIDER_PASSWORD=wheatfill

# Optional demo patient for pharmacy checkout (backend JWT / Stripe redirect)
DEFAULT_PATIENT_USERNAME=demo
DEFAULT_PATIENT_PASSWORD=wheatfill

# Clover Hosted Checkout
CLOVER_ENV=sandbox
CLOVER_MERCHANT_ID=
CLOVER_PRIVATE_KEY=
CLOVER_WEBHOOK_SECRET=

# Encryption key for storing provider secrets (32 bytes, base64 recommended)
APP_ENCRYPTION_KEY=

# Stripe (optional; for Stripe Connect + webhooks)
STRIPE_SECRET_KEY=
STRIPE_CONNECT_CLIENT_ID=
STRIPE_WEBHOOK_SECRET=

# Medplum (optional) - used to update FHIR resources on payment webhooks
MEDPLUM_BASE_URL=https://api.medplum.com
MEDPLUM_CLIENT_ID=
MEDPLUM_CLIENT_SECRET=
PROVIDER_PRACTITIONER_ID=

# Optional: public video visit room URL (used by frontend patient portal)
# VITE_VIDEO_VISIT_URL=

