VITE_MARKETING_ONLY=1
# Full practice app URL (AWS, etc.). GitHub Actions defaults to https://wheatfillprecisionhealth.com for same-origin marketing.
VITE_APP_URL=

# Public API base (https, no trailing slash). Local dev: http://localhost:8080. Live: GitHub Actions defaults to
# https://api.wheatfillprecisionhealth.com (set repository secret VITE_API_URL if your API is hosted elsewhere).
# VITE_API_URL=https://api.wheatfillprecisionhealth.com

# Optional: use your PayPal.me or another pay link. Default is “Buy Now” to the practice email (not /donate).
# VITE_PAYPAL_PAY_URL=https://www.paypal.com/paypalme/yourhandle

